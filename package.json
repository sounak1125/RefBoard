{
  "name": "refboard",
  "productName": "RefBoard",
  "version": "2.0.0",
  "description": "A fast, clean moodboard and reference app. Made by Sounak.",
  "author": "Sounak",
  "license": "MIT",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/sounak1125/RefBoard.git"
  },
  "homepage": "https://github.com/sounak1125/RefBoard",
  "bugs": {
    "url": "https://github.com/sounak1125/RefBoard/issues"
  },
  "scripts": {
    "start": "electron .",
    "test": "node scripts/test-group-model.mjs && node scripts/test-group-marquee-selection.mjs && node scripts/test-export-order.mjs && node scripts/test-shell-integration.mjs && node scripts/test-thumbnail-preview.mjs && node scripts/test-landing-layout.mjs && node scripts/test-toolbar-mode.mjs && node scripts/test-theme-system.mjs && node scripts/test-draw-panel-contract.mjs && node scripts/test-selection-tools-contract.mjs && node scripts/test-note-roundtrip.mjs && node scripts/test-note-parsers.mjs && node scripts/test-image-decode-queue.mjs && node scripts/test-image-residency.mjs && node scripts/test-image-render-stability.mjs && node scripts/test-cropped-export.mjs && node scripts/test-clipboard-copy-order.mjs && node scripts/test-board-save-format.mjs && node scripts/test-board-save-as-contract.mjs && node scripts/test-board-open-stream.mjs && node scripts/test-navigation-guards.mjs && node scripts/test-animatics-timeline-model.mjs && node scripts/test-animatics-visual-transform.mjs && node scripts/test-animatics-audio-model.mjs && node scripts/test-animatics-premiere-export.mjs && node scripts/test-animatics-after-effects-export.mjs && node scripts/test-animatics-contract.mjs && node scripts/test-changelog-format.mjs",
    "test:landing-smoke": "electron scripts/smoke-landing-layout.js",
    "test:theme-smoke": "node scripts/smoke-theme-system.mjs",
    "predist": "npm test && node scripts/sync-changelog.mjs",
    "dist": "electron-builder --win",
    "dist:publish": "electron-builder --win --publish always",
    "gen:icon": "node scripts/gen-icon.js",
    "build:thumb-handler": "node scripts/build-thumb-handler.js",
    "test:animatics-smoke": "node scripts/smoke-animatics-transform.mjs && node scripts/smoke-animatics-sequence.mjs && node scripts/smoke-animatics-linked-drag.mjs && node scripts/smoke-animatics-track-controls.mjs && node scripts/smoke-animatics-audio-workflow.mjs",
    "release:publish": "powershell -ExecutionPolicy Bypass -File scripts/publish-local-dist.ps1 -ReplaceAssets",
    "release:ship": "powershell -ExecutionPolicy Bypass -File scripts/ship-release.ps1 -DistDir dist-release -Draft",
    "release:fix-v100-assets": "powershell -ExecutionPolicy Bypass -File scripts/upload-release-assets.ps1 -Tag v1.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "ffmpeg-static": "^5.2.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.0",
    "sharp": "^0.35.3",
    "to-ico": "^1.1.5"
  },
  "build": {
    "appId": "com.sounak.refboard",
    "productName": "RefBoard",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "scripts/note-dom.mjs",
      "scripts/clipboard-copy-order.mjs",
      "scripts/export-order.mjs",
      "scripts/navigation-guards.mjs",
      "scripts/animatics-timeline-model.mjs",
      "scripts/animatics-visual-transform.mjs",
      "scripts/animatics-audio-model.mjs",
      "scripts/animatics-premiere-export.mjs",
      "scripts/animatics-after-effects-export.mjs",
      "scripts/animatics.mjs",
      "scripts/image-residency.mjs",
      "scripts/image-render-demand.mjs",
      "scripts/shell-integration.js",
      "scripts/board-save-format.js",
      "scripts/board-open-stream.js",
      "changelog.json",
      "package.json",
      "assets/icons/sel/**"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build/thumbnail-handler/bin/RefBoardThumbnailHandler.dll",
        "to": "RefBoardThumbnailHandler.dll"
      },
      {
        "from": "build/thumbnail-handler/bin/SharpShell.dll",
        "to": "SharpShell.dll"
      },
      {
        "from": "scripts/register-thumb-handler.ps1",
        "to": "scripts/register-thumb-handler.ps1"
      }
    ],
    "fileAssociations": [
      {
        "ext": "refboard",
        "name": "RefBoard moodboard",
        "description": "RefBoard moodboard file",
        "icon": "build/icon.ico",
        "role": "Editor"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "sounak1125",
      "repo": "RefBoard"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "license": "build/license.txt",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeader": "build/installerHeader.bmp",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "createDesktopShortcut": true,
      "shortcutName": "RefBoard",
      "artifactName": "RefBoard-Setup-${version}.exe",
      "include": "build/installer.nsh"
    }
  }
}
